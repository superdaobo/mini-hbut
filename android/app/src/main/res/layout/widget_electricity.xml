<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_elec_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0FFFFFF"
    android:padding="14dp"
    android:clipToOutline="true">

    <TextView
        android:id="@+id/widget_elec_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚡ 电费余量"
        android:textColor="#FF1A2332"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/widget_elec_quantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#FF2563EB"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/widget_elec_room"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FF5C6B7A"
        android:textSize="11sp"
        android:gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_elec_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#FF2563EB"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp"
        android:visibility="gone" />

</LinearLayout>
