<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_exam_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFFFF"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_exam_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📝 即将考试"
            android:textColor="#FF1A2332"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_exam_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFEF4444"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_exam_course"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FF1A2332"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/widget_exam_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FF5C6B7A"
        android:textSize="12sp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/widget_exam_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF2563EB"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
