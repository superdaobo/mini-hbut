<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_exam_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- 标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/widget_dot_accent"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_exam_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📝 即将考试"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- 倒计时胶囊 -->
        <TextView
            android:id="@+id/widget_exam_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_capsule_accent"
            android:textColor="@color/widget_accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_divider"
        android:layout_marginBottom="8dp" />

    <!-- 课程名 -->
    <TextView
        android:id="@+id/widget_exam_course"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/widget_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <!-- 日期时间 -->
    <TextView
        android:id="@+id/widget_exam_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/widget_text_secondary"
        android:textSize="12sp"
        android:paddingBottom="4dp" />

    <!-- 地点 -->
    <TextView
        android:id="@+id/widget_exam_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_capsule_location"
        android:textColor="@color/widget_location_text"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone" />

</LinearLayout>
