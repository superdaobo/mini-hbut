{
  "name": "mini-hbut",
  "version": "1.4.2",
  "description": "Mini-HBUT - 湖北工业大学教务助手",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "node scripts/prepare_dist.mjs",
    "prebuild:web": "node scripts/prepare_dist.mjs",
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "build:hot-bundle": "node scripts/build_hot_bundle.mjs",
    "test": "vitest run",
    "test:ci": "vitest run --config vitest.ci.config.ts",
    "test:pbt": "vitest run -t \"Property\"",
    "test:debug-bridge-contract": "node scripts/test_debug_bridge_contract.mjs",
    "test:debug-ui-capture": "node scripts/debug_capture_ui.mjs",
    "test:hot-update-framework": "node scripts/test_hot_update_framework.mjs",
    "test:more-module-bridge": "node scripts/test_more_module_bridge.mjs",
    "test:resource-share-network": "node scripts/test_resource_share_network.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:debug-bridge": "node scripts/run_tauri_debug_dev.mjs",
    "cap:sync": "npm run build:web && npx cap sync",
    "cap:run:android": "npm run build:web && npx cap run android",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/app-launcher": "^6.0.4",
    "@capacitor/browser": "^6.0.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/share": "^6.0.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-fs": "^2.3.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.4",
    "@transistorsoft/capacitor-background-fetch": "^6.0.2",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.1.6",
    "fflate": "^0.8.2",
    "html2canvas": "^1.4.1",
    "marked": "^12.0.2",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.4",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.6.0",
    "tauri-plugin-keep-screen-on-api": "^0.1.4",
    "vue": "^3.4.0",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1",
    "ajv": "^8",
    "autoprefixer": "^10.5.0",
    "fast-check": "^3",
    "material-symbols": "^0.44.8",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1",
    "vue-tsc": "^1.8.0"
